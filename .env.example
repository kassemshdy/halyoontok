# ============================================
# HalyoonTok Environment Variables
# ============================================

# --- Database (Railway provides DATABASE_URL) ---
DATABASE_URL=postgresql://halyoontok:halyoontok@localhost:5432/halyoontok
# Or individual vars (used when DATABASE_URL is empty):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=halyoontok
# POSTGRES_PASSWORD=halyoontok
# POSTGRES_DB=halyoontok

# --- Redis (Railway provides REDIS_URL) ---
REDIS_URL=redis://localhost:6379/0
# Or individual vars:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --- Auth ---
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRATION_MINUTES=60

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Storage ---
STORAGE_BACKEND=local
# For local dev:
MEDIA_BASE_URL=http://localhost:8083
LOCAL_STORAGE_DIR=./media-api/storage

# For production (Cloudflare R2):
# STORAGE_BACKEND=r2
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET_NAME=halyoontok-media
# R2_PUBLIC_URL=https://media.halyoontok.com
# MEDIA_BASE_URL=https://media.halyoontok.com

# --- Sentry (optional) ---
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Logging ---
# LOG_FORMAT=json

# --- Social Media APIs ---
# YOUTUBE_API_KEY=your-youtube-data-api-key
# TIKTOK_API_KEY=your-tiktok-research-api-key
# INSTAGRAM_ACCESS_TOKEN=your-instagram-graph-api-token
# DATA_COLLECTION_INTERVAL_HOURS=6

# --- AI Video Generation ---
# AI_GENERATION_API_URL=https://api.example.com/v1/generate
# AI_GENERATION_API_KEY=your-generation-api-key
# DEFAULT_GENERATION_MODEL=nano_banana

# --- Celery ---
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Frontend ---
NEXT_PUBLIC_FRONT_API_URL=http://localhost:8081
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8080
NEXT_PUBLIC_UPLOAD_API_URL=http://localhost:8082
NEXT_PUBLIC_MEDIA_URL=http://localhost:8083
